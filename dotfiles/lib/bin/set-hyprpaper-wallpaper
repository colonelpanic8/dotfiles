#!/usr/bin/env bash

set -u

wallpaper_dir="${WALLPAPER_DIR:-/var/lib/syncthing/sync/Wallpaper/use}"
wallpaper_variant_root="${WALLPAPER_VARIANT_ROOT:-}"
hyprctl_bin="${HYPRCTL:-hyprctl}"
runtime_dir="${XDG_RUNTIME_DIR:-}"
sig="${HYPRLAND_INSTANCE_SIGNATURE:-}"
sock_path=""

resolve_wallpaper_variant() {
  local selected="$1"
  local target_width="$2"
  local target_height="$3"
  local root="$wallpaper_variant_root"
  local selected_name selected_stem candidate

  if [ -z "$root" ]; then
    root="$(cd "$wallpaper_dir/.." && pwd -P)"
  fi

  selected_name="$(basename "$selected")"
  selected_stem="${selected_name%.*}"
  candidate="$root/${target_width}x${target_height}/$selected_stem.png"

  if [ -f "$candidate" ]; then
    printf '%s\n' "$candidate"
  else
    printf '%s\n' "$selected"
  fi
}

if [ -n "$runtime_dir" ] && [ -n "$sig" ]; then
  sock_path="$runtime_dir/hypr/$sig/.hyprpaper.sock"
fi

# Don't fail the service if Hyprland has not exported its instance yet.
if [ -z "$sock_path" ]; then
  echo "set-hyprpaper-wallpaper: missing XDG_RUNTIME_DIR/HYPRLAND_INSTANCE_SIGNATURE" >&2
  exit 0
fi

for _ in {1..50}; do
  if [ -S "$sock_path" ]; then
    break
  fi
  sleep 0.1
done

if [ ! -S "$sock_path" ]; then
  echo "set-hyprpaper-wallpaper: hyprpaper socket not ready at $sock_path" >&2
  exit 0
fi

if [ ! -d "$wallpaper_dir" ]; then
  echo "set-hyprpaper-wallpaper: wallpaper directory missing: $wallpaper_dir" >&2
  exit 0
fi

wallpaper="$(find -L "$wallpaper_dir" -type f -regextype posix-extended -iregex '.*\.(png|jpe?g|webp)$' -print0 | shuf -z -n 1 | tr -d '\0')"

if [ -z "$wallpaper" ]; then
  echo "set-hyprpaper-wallpaper: no wallpapers found in $wallpaper_dir" >&2
  exit 0
fi

monitors="$("$hyprctl_bin" -j monitors 2>/dev/null | jq -r \
  '.[] | [.name, .width, .height] | @tsv' 2>/dev/null || true)"
if [ -z "$monitors" ]; then
  monitors="$("$hyprctl_bin" monitors 2>/dev/null \
    | grep -oE '^Monitor [^ ]+' \
    | cut -d' ' -f2 \
    | awk '{ print $1 "\t0\t0" }' || true)"
fi

while IFS=$'\t' read -r mon width height; do
  [ -z "$mon" ] && continue

  monitor_wallpaper="$wallpaper"
  if [ "${width:-0}" -gt 0 ] && [ "${height:-0}" -gt 0 ]; then
    monitor_wallpaper="$(resolve_wallpaper_variant "$wallpaper" "$width" "$height")"
  fi

  echo "set-hyprpaper-wallpaper: $mon ${width}x${height} -> $monitor_wallpaper"

  # The socket file can exist before hyprpaper is actually ready to accept IPC.
  for _ in {1..50}; do
    if "$hyprctl_bin" hyprpaper wallpaper "$mon,$monitor_wallpaper" >/dev/null 2>&1; then
      break
    fi
    sleep 0.1
  done
done <<< "$monitors"

exit 0
