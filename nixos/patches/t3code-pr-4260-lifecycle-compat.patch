+          ) : null}
+        </div>
+        <div className="flex shrink-0 items-center gap-0.5">
+          {goal.status === "active" ? (
+            <Button
+              variant="ghost"
+              size="icon-xs"
+              disabled={props.pending}
+              aria-label="Pause goal"
+              title="Pause goal"
+              onClick={props.onPause}
+            >
