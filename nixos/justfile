switch *args:
	dotfiles_worktree="$(/run/current-system/sw/bin/readlink -f "$PWD/..")"; if [ "$dotfiles_worktree" != /srv/dotfiles ]; then echo "Refusing to activate dotfiles from non-primary checkout: $dotfiles_worktree" >&2; exit 1; fi; case "$(/run/current-system/sw/bin/systemctl show -P ActiveState nixos-upgrade.service 2>/dev/null)" in active|activating|reloading) /run/wrappers/bin/sudo /run/current-system/sw/bin/systemctl stop nixos-upgrade.service;; esac; /run/wrappers/bin/sudo env DOTFILES_WORKTREE="$dotfiles_worktree" PATH=/run/current-system/sw/bin:/nix/var/nix/profiles/system/sw/bin:/etc/profiles/per-user/root/bin:/usr/bin:/bin /run/current-system/sw/bin/nixos-rebuild switch --flake ".#" --impure --option substituters '{{switch-substituters}}' --option trusted-public-keys '{{switch-trusted-public-keys}}' --option connect-timeout 3 --option fallback true --option download-attempts 2 {{args}}

bump-tracked-flakes *args:
	PATH=/run/current-system/sw/bin:/nix/var/nix/profiles/system/sw/bin:/etc/profiles/per-user/root/bin:/usr/bin:/bin nix flake update {{tracked-flake-inputs}}
	just switch {{args}}

bump-t3code *args:
	PATH=/run/current-system/sw/bin:/nix/var/nix/profiles/system/sw/bin:/etc/profiles/per-user/root/bin:/usr/bin:/bin nix flake update t3code-upstream
	just switch {{args}}

# Commit/tag-pinned inputs remain fixed until their flake URLs are changed.
bump-hyprland *args:
	PATH=/run/current-system/sw/bin:/nix/var/nix/profiles/system/sw/bin:/etc/profiles/per-user/root/bin:/usr/bin:/bin nix flake update {{hyprland-flake-inputs}}
	just switch {{args}}

populate-cachix cache="colonelpanic8-dotfiles" host=`hostname` *args:
	store_path="$(nix build --no-link --print-out-paths ".#nixosConfigurations.{{host}}.config.system.build.toplevel" --impure --option warn-dirty false {{args}})" && cachix push {{cache}} "$store_path"

publish-hyprland-cachix cache="colonelpanic8-dotfiles" *args:
	store_paths="$(nix build --no-link --print-out-paths ".#hyprland-stuff" --option warn-dirty false {{args}})" && cachix push {{cache}} $store_paths
